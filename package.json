{
  "name": "voleeo",
  "private": true,
  "license": "MIT",
  "version": "0.1.0",
  "workspaces": ["src-web", "packages/*", "plugins/*"],
  "scripts": {
    "dev": "tauri dev --config src-tauri/tauri.dev.conf.json",
    "build": "tauri build",
    "codegen": "TAURI_CONFIG='{\"bundle\":{\"externalBin\":[]}}' cargo run -p codegen",
    "mcp-bridge:build": "cargo build --bin voleeo-mcp-bridge",
    "typecheck": "cd src-web && bun run typecheck",
    "test": "cd src-web && bun run test",
    "lint": "cd src-web && bun run lint",
    "lint:fix": "cd src-web && bun run lint:fix",
    "format": "cd src-web && bun run format"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "@types/node": "^26.0.0",
    "shadcn": "^4.3.1"
  }
}
